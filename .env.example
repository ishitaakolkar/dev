# AI Job Application Assistant - Environment Variables

# Required for AI features (job matching, email generation, project selection)
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Required for email sending
# Your Gmail address
GMAIL_EMAIL=your_email@gmail.com

# Gmail App Password (not your regular password)
# Generate at: https://myaccount.google.com/apppasswords
# 1. Enable 2-factor authentication on your Gmail account
# 2. Go to Google Account settings → Security → 2-Step Verification → App passwords
# 3. Generate a new app password for "Job Agent"
GMAIL_APP_PASSWORD=your_gmail_app_password_here

# Current Company (to avoid accidentally applying to your current employer)
# The system will skip any jobs from this company
CURRENT_COMPANY=your_current_company_name_here

# Optional: Override default settings (uncomment and modify if needed)
# MATCH_SCORE_THRESHOLD=70
# MAX_EXPERIENCE_YEARS=2
# MAX_EMAILS_PER_DAY=5
# JOB_SEARCH_INTERVAL_HOURS=6
